---
import { getCollection, render } from 'astro:content';
import MainLayout from '@src/layouts/MainLayout.astro';
import SocialShare from '@src/components/SocialShare.astro';
import PostProfile from '@src/components/PostProfile.astro';
import PostRelated from '@src/components/PostRelated.astro';
import CategoryWidget from '@src/components/CategoryWidget.astro';
import FeaturedPostWidget from '@src/components/FeaturedPostWidget.astro';
import TagsWidget from '@src/components/TagsWidget.astro';
import { Icon } from 'astro-icon/components';
import { url } from '@src/utils/path';
import { getAuthor } from '@src/data/authorData';

const RESERVED = new Set([
  // static files
  'index', '404', 'contact', 'cookies', 'privacy', 'terms',
  'author', 'blog', 'category', 'page', 'search', 'tags',
  'about', 'docs', 'careers', 'advertise', 'news',
]);

export async function getStaticPaths() {
  const RESERVED = new Set([
    'index', '404', 'contact', 'cookies', 'privacy', 'terms',
    'author', 'blog', 'category', 'page', 'search', 'tags',
    'about', 'docs', 'careers', 'advertise', 'news',
  ]);

  const allPosts = await getCollection('blog');

  return allPosts
    .filter((post) => !RESERVED.has(post.id.toLowerCase()))
    .map((post) => ({
      params: { slug: post.id },
      props:  { post },
    }));
}

// ── Props & render ────────────────────────────────────────────────────────────
const { post } = Astro.props;
const { Content } = await render(post);

const {
  title,
  cover,
  date,
  category,
  tags     = [],
  authorId,
  excerpt,
  readTime,
} = post.data;

const variant = 'standard' as 'fullwidth' | 'standard';

// ── Author ────────────────────────────────────────────────────────────────────
const author = getAuthor(authorId);

// ── Related posts (same category, exclude self, max 3) ────────────────────────
const allPosts = await getCollection('blog');
const related = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .filter((p) => p.id !== post.id && p.data.category === category)
  .slice(0, 3)
  .map((p) => ({
    slug:  p.id,
    title: p.data.title,
    cover: p.data.cover,
    date:  p.data.date,
  }));

// ── Helpers ───────────────────────────────────────────────────────────────────
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});

const categorySlug = category.toLowerCase().replace(/\s+/g, '-');

function tagSlug(t: string) {
  return t.toLowerCase().replace(/\s+/g, '-');
}
---

<MainLayout title={`${title}`} description={excerpt}>
  <div class="container xl:max-w-7xl mx-auto px-4 flex flex-col gap-4 lg:gap-6">
    {variant === 'fullwidth' ? (
      <div class="grid grid-cols-1 py-6">
        <div class="relative">
          <h1 class="text-2xl md:text-3xl lg:text-4xl md:text-center font-medium py-4">{title}</h1>

          <!-- Meta -->
          <div class="pb-4 w-full flex flex-wrap items-center md:justify-center gap-4 text-sm text-slate-500 border-b border-slate-200">
            <a href={url(author.href)} rel="author" class="flex items-center gap-1.5 hover:text-black">
              <Icon name="bi:person" class="size-3.5" />
              by {author.name}
            </a>
            <time datetime={date} class="flex items-center gap-1.5">
              <Icon name="bi:calendar" class="size-3.5" />
              {formattedDate}
            </time>
            <a href={url(`/category/${categorySlug}`)} rel="category" class="flex items-center gap-1.5 hover:text-black">
              <Icon name="bi:bookmark" class="size-3.5" />
              {category}
            </a>
            <span class="flex items-center gap-1.5">
              <Icon name="bi:clock" class="size-3.5" />
              {readTime} min read
            </span>
          </div>

          <!-- Cover -->
          <div class="aspect-2/1 overflow-hidden w-full bg-slate-100 my-6 rounded-lg">
            <img src={url(cover)} alt={title} class="w-full h-full object-cover" />
          </div>

          <!-- Content -->
          <div class="relative post-content pt-2">
            <Content />
          </div>

          <!-- Tags + Share -->
          <div class="flex flex-col sm:flex-row items-center justify-between gap-3 py-4 border-y border-slate-200 mt-8">
            <ul class="flex flex-wrap items-center gap-2 text-sm">
              <li><Icon name="bi:tags" class="size-4 text-slate-400" /></li>
              {tags.map((tag) => (
                <li>
                  <a href={url(`/tags/${tagSlug(tag)}`)} class="flex py-1 px-3 bg-white hover:bg-slate-100 border rounded-sm border-slate-200">{tag}</a>
                </li>
              ))}
            </ul>
            <SocialShare title={title} pageUrl={Astro.url.href} />
          </div>

          <PostProfile author={author} />
          <PostRelated posts={related} />
        </div>
      </div>

    ) : (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6 py-6">
        <div class="lg:col-span-2 py-4">
          <h1 class="text-2xl md:text-3xl font-medium py-4">{title}</h1>
          <!-- Meta -->
          <div class="pb-4 w-full flex flex-wrap items-center gap-4 text-sm text-slate-500 border-b border-slate-200">
            <a href={url(author.href)} rel="author" class="flex items-center gap-1.5 hover:text-black">
              <Icon name="bi:person" class="size-3.5" />
              by {author.name}
            </a>
            <time datetime={date} class="flex items-center gap-1.5">
              <Icon name="bi:calendar" class="size-3.5" />
              {formattedDate}
            </time>
            <a href={url(`/category/${categorySlug}`)} rel="category" class="flex items-center gap-1.5 hover:text-black">
              <Icon name="bi:bookmark" class="size-3.5" />
              {category}
            </a>
            <span class="flex items-center gap-1.5">
              <Icon name="bi:clock" class="size-3.5" />
              {readTime} min read
            </span>
          </div>

          <!-- Cover -->
          <div class="aspect-2/1 overflow-hidden w-full bg-slate-100 rounded-lg my-6">
            <img src={url(cover)} alt={title} class="w-full h-full object-cover" />
          </div>

          <!-- Content -->
          <div class="relative post-content pt-2">
            <Content />
          </div>

          <!-- Tags + Share -->
          <div class="flex flex-col sm:flex-row items-center justify-between gap-3 py-4 border-y border-slate-200 mt-8">
            <ul class="flex flex-wrap items-center gap-2 text-sm">
              <li><Icon name="bi:tags" class="size-4 text-slate-400" /></li>
              {tags.map((tag) => (
                <li>
                  <a href={url(`/tags/${tagSlug(tag)}`)} class="flex py-1 px-3 bg-white hover:bg-slate-100 rounded-sm border border-slate-200">{tag}</a>
                </li>
              ))}
            </ul>
            <SocialShare title={title} pageUrl={Astro.url.href} />
          </div>

          <PostProfile author={author} />
          <PostRelated posts={related} />
        </div>
        
        <aside class="lg:col-span-1 lg:ps-6">
          <div class="flex flex-col gap-4 lg:gap-6 top-24 sticky">
            <CategoryWidget />
            <FeaturedPostWidget />
            <TagsWidget />
          </div>
        </aside>
      </div>
    )}
  </div>
</MainLayout>
