---
import { getCollection } from 'astro:content';
import CategoryListLayout from '@src/layouts/CategoryListLayout.astro';

export async function getStaticPaths() {
  const PER_PAGE = 8;

  const allPosts = (await getCollection('blog')).sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

  const categoryMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    const slug = post.data.category.toLowerCase().replace(/\s+/g, '-');
    if (!categoryMap.has(slug)) categoryMap.set(slug, []);
    categoryMap.get(slug)!.push(post);
  }

  const paths: {
    params: { category: string; page: string };
    props:  {
      pagePosts:    typeof allPosts;
      totalPages:   number;
      currentPage:  number;
      categoryName: string;
      categorySlug: string;
    };
  }[] = [];

  for (const [slug, posts] of categoryMap.entries()) {
    const totalPages = Math.ceil(posts.length / PER_PAGE);

    for (let page = 2; page <= totalPages; page++) {
      const start = (page - 1) * PER_PAGE;
      paths.push({
        params: { category: slug, page: String(page) },
        props:  {
          pagePosts:    posts.slice(start, start + PER_PAGE),
          totalPages,
          currentPage:  page,
          categoryName: posts[0].data.category,
          categorySlug: slug,
        },
      });
    }
  }

  return paths;
}

interface Props {
  pagePosts:    Awaited<ReturnType<typeof getCollection<'blog'>>>;
  totalPages:   number;
  currentPage:  number;
  categoryName: string;
  categorySlug: string;
}

const { pagePosts, totalPages, currentPage, categoryName, categorySlug } = Astro.props;
---

<CategoryListLayout
  posts={pagePosts}
  currentPage={currentPage}
  totalPages={totalPages}
  categoryName={categoryName}
  categorySlug={categorySlug}
/>
