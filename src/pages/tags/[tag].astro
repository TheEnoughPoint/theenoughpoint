---
import { getCollection } from 'astro:content';
import CategoryListLayout from '@src/layouts/CategoryListLayout.astro';

export async function getStaticPaths() {
  const PER_PAGE = 8;

  const allPosts = (await getCollection('blog')).sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

  const tagMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    for (const tag of post.data.tags ?? []) {
      const slug = tag.toLowerCase().replace(/\s+/g, '-');
      if (!tagMap.has(slug)) tagMap.set(slug, []);
      tagMap.get(slug)!.push(post);
    }
  }

  return [...tagMap.entries()].map(([slug, posts]) => {
    const tagName =
      posts.flatMap((p) => p.data.tags ?? [])
           .find((t) => t.toLowerCase().replace(/\s+/g, '-') === slug) ?? slug;

    return {
      params: { tag: slug },
      props:  {
        pagePosts:  posts.slice(0, PER_PAGE),
        totalPages: Math.ceil(posts.length / PER_PAGE),
        tagName,
        basePath:   `/tags/${slug}`,
      },
    };
  });
}

interface Props {
  pagePosts:  Awaited<ReturnType<typeof getCollection<'blog'>>>;
  totalPages: number;
  tagName:    string;
  basePath:   string;
}

const { pagePosts, totalPages, tagName, basePath } = Astro.props;
---

<CategoryListLayout
  posts={pagePosts}
  currentPage={1}
  totalPages={totalPages}
  categoryName={`#${tagName}`}
  categorySlug={basePath}
  description={`All posts tagged with "${tagName}".`}
/>
