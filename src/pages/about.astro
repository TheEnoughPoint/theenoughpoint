---
import MainLayout from '@src/layouts/MainLayout.astro';
import AboutHero from '@src/components/AboutHero.astro';
import AboutMission from '@src/components/AboutMission.astro';
import AboutValues from '@src/components/AboutValues.astro';
import AboutTimeline from '@src/components/AboutTimeline.astro';
import AboutGallery from '@src/components/AboutGallery.astro';
import RightSidebar from '@src/components/RightSidebar.astro';
import TagsWidget from '@src/components/TagsWidget.astro';
import { defaultAboutData } from '@src/data/aboutData';

const about = defaultAboutData;
---

<MainLayout
  title={`About ${about.name}`}
  description={about.intro[0]}
>
  <div class="container xl:max-w-7xl mx-auto px-4 flex flex-col gap-4 lg:gap-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6 py-6">
      <!-- Main content -->
      <div class="max-lg:mb-12 lg:col-span-2">
        <AboutHero about={about} />
        <AboutMission mission={about.mission} />
        <AboutValues values={about.values} />
        <AboutTimeline timeline={about.timeline} />
        {about.gallery.length > 0 && <AboutGallery gallery={about.gallery} />}
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1 lg:ps-6">
        <div class="flex flex-col gap-4 lg:gap-6 sticky top-24">
          <RightSidebar />
          <TagsWidget />
        </div>
      </aside>
    </div>
  </div>
</MainLayout>