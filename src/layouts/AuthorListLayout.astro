---
import MainLayout from '@src/layouts/MainLayout.astro';
import HeroAuthor from '@src/components/HeroAuthor.astro';
import PostCard from '@src/components/PostCard.astro';
import Pagination from '@src/components/Pagination.astro';
import CategoryWidget from '@src/components/CategoryWidget.astro';
import FeaturedPostWidget from '@src/components/FeaturedPostWidget.astro';
import TagsWidget from '@src/components/TagsWidget.astro';
import type { CollectionEntry } from 'astro:content';
import type { AuthorData } from '@src/data/authorData';

interface Props {
  posts:       CollectionEntry<'blog'>[];
  currentPage: number;
  totalPages:  number;
  author:      AuthorData;
  basePath:    string;
}

const { posts, currentPage, totalPages, author, basePath } = Astro.props;

const pageTitle = currentPage === 1
  ? `${author.fullName}`
  : `${author.fullName} · Page ${currentPage}`;

const pageDescription = currentPage === 1
  ? author.bio
  : `Posts by ${author.fullName} — page ${currentPage} of ${totalPages}.`;
---

<MainLayout title={pageTitle} description={pageDescription}>

  <HeroAuthor author={author} />

  <div class="container xl:max-w-7xl mx-auto px-4 flex flex-col gap-4 lg:gap-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6 py-6 lg:py-12">
      <!-- Post list -->
      <div class="max-lg:mb-12 lg:col-span-2">
        <h2 class="text-lg uppercase font-medium border-b border-slate-200 pb-2">
          Posts by {author.name}
          {currentPage > 1 && (
            <span class="text-slate-400 text-base font-normal normal-case"> — Page {currentPage}</span>
          )}
        </h2>

        {posts.length > 0 ? (
          <div class="flex flex-col">
            {posts.map((post) => (
              <PostCard
                id={post.id}
                title={post.data.title}
                cover={post.data.cover}
                date={post.data.date}
                authorId={post.data.authorId}
                excerpt={post.data.excerpt}
              />
            ))}
          </div>
        ) : (
          <p class="py-12 text-center text-slate-400">No posts found for this author.</p>
        )}

        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          basePath={basePath}
        />
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1 lg:ps-6 relative">
        <div class="flex flex-col gap-4 lg:gap-6 sticky top-24">
          <CategoryWidget />
          <FeaturedPostWidget />
          <TagsWidget />
        </div>
      </aside>

    </div>
  </div>
</MainLayout>
