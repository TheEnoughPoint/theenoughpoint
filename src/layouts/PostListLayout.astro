---
import MainLayout from '@src/layouts/MainLayout.astro';
import HeroSection from '@src/components/HeroSection.astro';
import BlockNews from '@src/components/BlockNews.astro';
import BlockNewsOne from '@src/components/BlockNewsOne.astro';
import BlockNewsTwo from '@src/components/BlockNewsTwo.astro';
import BlockNewsPopular from '@src/components/BlockNewsPopular.astro';
import BlockNewsScroll from '@src/components/BlockNewsScroll.astro';
import SocialMediaWidget from '@src/components/SocialMediaWidget.astro';
import AdsSidebar from '@src/components/AdsSidebar.astro';
import NewsletterArea from '@src/components/NewsletterArea.astro';
import PostCard from '@src/components/PostCard.astro';
import Pagination from '@src/components/Pagination.astro';
import FeaturedPostWidget from '@src/components/FeaturedPostWidget.astro';
import TagsWidget from '@src/components/TagsWidget.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  currentPage: number;
  totalPages: number;
  showHero?: boolean;
}

const { posts, currentPage, totalPages, showHero = false } = Astro.props;

const pageTitle = currentPage === 1
  ? ' News magazine Astro Theme - Portal'
  : ` Page ${currentPage} - Portal`;

const pageDescription = currentPage === 1
  ? 'Portal is a Astro news magazine theme. This demo is crafted specifically to exhibit the use of the theme as a news site.'
  : `Browse all blog posts — page ${currentPage} of ${totalPages}.`;

const basePath = '/';
---

<MainLayout title={pageTitle} description={pageDescription}>
  <div class="container xl:max-w-7xl mx-auto px-4 flex flex-col gap-4 lg:gap-6">
    {showHero && 
    <HeroSection variant="fade" />
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6 py-6 mb-12">
      <!-- Post list -->
      <div class="max-lg:mb-12 lg:col-span-2">
        <BlockNews category="politics" />
        <BlockNewsOne category="sports" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          <BlockNewsTwo category="lifestyle" />
          <BlockNewsTwo category="foods" />
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1 lg:ps-6 relative">
        <div class="flex flex-col gap-4 lg:gap-6 top-24 sticky">
          <SocialMediaWidget />
          <BlockNewsPopular typePost="trending" title="Trending Post" limit={5} />
          <AdsSidebar />
        </div>
      </aside>
    </div>

    <BlockNewsScroll title="Featured Picks" typePost="featured" limit={6} />
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6 py-6">
      <div class="max-lg:mb-12 lg:col-span-2">
        {showHero &&
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          <BlockNewsTwo category="technology" />
          <BlockNewsTwo category="entertainment" />
        </div>
        }

        <div class="relative">
          <!-- HeadingBlock -->
          <div class="flex items-center gap-3 justify-between">
            <h2 class="ps-2 border-s-2 border-brand-600 text-lg capitalize font-medium"> {currentPage === 1 ? 'Latest Post' : `Latest Post — Page ${currentPage}`}</h2>
          </div>

          <div class="flex flex-col">
            {posts.map((post) => (
              <PostCard
                id={post.id}
                title={post.data.title}
                cover={post.data.cover}
                date={post.data.date}
                authorId={post.data.authorId}
                excerpt={post.data.excerpt}
              />
            ))}
          </div>
        </div>

        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          basePath={basePath}
        />
      </div>
      <aside class="lg:col-span-1 lg:ps-6 relative">
        <div class="flex flex-col gap-4 lg:gap-6 top-24 sticky">
          <FeaturedPostWidget />
          <TagsWidget />
        </div>
      </aside>
    </div>

    <NewsletterArea />
  </div>
</MainLayout>