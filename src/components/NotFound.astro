---
import { url } from '@src/utils/path';

interface Props {
  code?: string | number;
  title?: string;
  message?: string;
  backLabel?: string;
  backHref?: string;
}

const {
  code      = '404',
  title     = 'Page Not Found',
  message   = 'The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.',
  backLabel = 'Back to Homepage',
  backHref  = '/',
} = Astro.props;
---

<section class="text-center border-b border-slate-200">
  <div class="max-w-2xl mx-auto py-12 px-6">
    <span class="text-6xl font-medium mb-4 block">{code}</span>
    <h1 class="text-2xl lg:text-3xl font-medium mb-6">{title}</h1>

    <!-- divider -->
    <div class="relative max-w-37.5 mx-auto mb-6">
      <div class="h-1 border-b-2 border-slate-200 w-full"></div>
      <div class="absolute inset-e-1/2 translate-x-2.5 -top-2.5 size-6 rounded-full bg-slate-100 border-2 border-slate-200"></div>
    </div>

    <p class="text-lg text-slate-500 mb-6">{message}</p>
    <a href={url(backHref)} class="mx-auto inline-flex py-2 px-4 bg-slate-100 hover:bg-slate-200/80 border border-slate-200">
      {backLabel}
    </a>
  </div>
</section>
