---
import { Icon } from 'astro-icon/components';
import { url } from '@src/utils/path';

interface Props {
  id:            string;
  title:         string;
  cover:         string;
  date:          string;
  authorId:      string;
  excerpt:       string;
  variant?: 'default' | 'grid' | 'box' | 'list' | 'feature';
  /** 'feature' variant only */
  featured?:     boolean;
  sponsored?:    boolean;
  sponsorName?:  string;
  lifeStage?:    string[];
}

const {
  id,
  title,
  cover,
  date,
  authorId,
  excerpt,
  variant       = 'default',
  featured      = false,
  sponsored     = false,
  sponsorName   = '',
  lifeStage     = [],
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  month: 'short',
  day:   '2-digit',
  year:  'numeric',
});

const postUrl   = url(`/${id}`);
const authorUrl = url(`/author/${authorId}`);
---

{variant === 'default' && (
  <article class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 py-8 border-b border-slate-200 last:border-b-0">
    <div class="group aspect-2/1 md:aspect-3/2 lg:apect-16/10 overflow-hidden rounded-lg w-full bg-slate-100">
      <a href={postUrl}>
        <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" src={url(cover)} loading="lazy" alt={title} />
      </a>
    </div>
    <div class="flex flex-col justify-start gap-2 lg:col-span-2">
      <h3 class="text-lg font-bold capitalize">
        <a href={postUrl} class="hover:text-brand-600">{title}</a>
      </h3>
      <div class="flex items-center gap-3 text-sm text-slate-500">
        <a href={authorUrl} rel="author" class="flex items-center gap-1 hover:text-black">
          <Icon name="bi:person" class="size-3.5" />{authorId}
        </a>
        <time datetime={date} class="flex items-center gap-1">
          <Icon name="bi:calendar" class="size-3.5" />{formattedDate}
        </time>
      </div>
      <p class="text-sm text-slate-500 line-clamp-3">{excerpt}</p>
    </div>
  </article>
)}

{variant === 'grid' && (
  <article class="flex flex-col gap-3">
    <div class="aspect-2/1 md:aspect-3/2 overflow-hidden w-full bg-slate-100">
      <a href={postUrl}>
        <img class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" src={url(cover)} loading="lazy" alt={title} />
      </a>
    </div>
    <div class="flex flex-col justify-start gap-2">
      <h3 class="text-xl capitalize">
        <a href={postUrl} class="hover:text-black">{title}</a>
      </h3>
      <div class="flex items-center gap-3 text-sm text-slate-500">
        <a href={authorUrl} rel="author" class="flex items-center gap-1 hover:text-black">
          <Icon name="bi:person" class="size-3.5" />{authorId}
        </a>
        <time datetime={date} class="flex items-center gap-1">
          <Icon name="bi:calendar" class="size-3.5" />{formattedDate}
        </time>
      </div>
      <p class="text-slate-500 mb-2 line-clamp-3">{excerpt}</p>
    </div>
  </article>
)}

{variant === 'box' && (
  <article class="flex flex-col">
    <div class="aspect-2/1 md:aspect-3/2 overflow-hidden w-full bg-slate-100">
      <a href={postUrl}>
        <img class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" src={url(cover)} loading="lazy" alt={title} />
      </a>
    </div>
    <div class="relative flex flex-col justify-start gap-2 py-6 px-6 bg-slate-50 border border-slate-200 rounded-lg mx-4 -mt-24 z-10">
      <h3 class="text-xl capitalize">
        <a href={postUrl} class="hover:text-black">{title}</a>
      </h3>
      <div class="flex items-center gap-3 text-sm text-slate-500">
        <a href={authorUrl} rel="author" class="flex items-center gap-1 hover:text-black">
          <Icon name="bi:person" class="size-3.5" />{authorId}
        </a>
        <time datetime={date} class="flex items-center gap-1">
          <Icon name="bi:calendar" class="size-3.5" />{formattedDate}
        </time>
      </div>
      <p class="text-slate-500 mb-2 line-clamp-3">{excerpt}</p>
    </div>
  </article>
)}

{variant === 'list' && (
  <article class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 py-8 border-b border-slate-200 last:border-b-0">
    <div class="aspect-2/1 md:aspect-3/2 overflow-hidden w-full bg-slate-100">
      <a href={postUrl}>
        <img class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" src={url(cover)} loading="lazy" alt={title} />
      </a>
    </div>
    <div class="flex flex-col justify-start gap-2 md:col-span-2">
      <h3 class="text-xl capitalize">
        <a href={postUrl} class="hover:text-black">{title}</a>
      </h3>
      <div class="flex items-center gap-3 text-sm text-slate-500">
        <a href={authorUrl} rel="author" class="flex items-center gap-1 hover:text-black">
          <Icon name="bi:person" class="size-3.5" />{authorId}
        </a>
        <time datetime={date} class="flex items-center gap-1">
          <Icon name="bi:calendar" class="size-3.5" />{formattedDate}
        </time>
      </div>
      <p class="text-slate-500 mb-2 line-clamp-3">{excerpt}</p>
    </div>
  </article>
)}

{variant === 'feature' && (
  <article class="flex flex-col bg-white border border-cream-dark rounded-lg overflow-hidden hover:shadow-md transition-shadow">
    <div class="relative aspect-3/2 overflow-hidden bg-cream">
      <a href={postUrl}>
        <img class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" src={url(cover)} loading="lazy" alt={title} />
      </a>
      {featured && (
        <span class="absolute top-3 left-3 bg-navy text-white text-[10px] font-bold uppercase tracking-wide px-2.5 py-1 rounded">Featured</span>
      )}
      {sponsored && (
        <span class="absolute top-3 left-3 bg-gold text-white text-[10px] font-bold uppercase tracking-wide px-2.5 py-1 rounded">Sponsored</span>
      )}
    </div>
    <div class="flex flex-col gap-2 p-4">
      <h3 class="text-navy font-heading font-bold text-base leading-snug">
        <a href={postUrl} class="hover:text-brand-600">{title}</a>
      </h3>
      <p class="text-muted text-sm line-clamp-2">{excerpt}</p>
      <a href={postUrl} class="inline-flex items-center gap-1 text-forest hover:text-forest-dark text-xs font-semibold">
        Read more
        <Icon name="bi:arrow-right" class="size-3" />
      </a>
    </div>
    <div class="px-4 pb-4">
      {sponsored ? (
        <span class="text-subtle text-xs">Sponsored by {sponsorName}</span>
      ) : lifeStage.length > 0 && (
        <ul class="flex flex-wrap gap-1.5">
          {lifeStage.map((stage) => (
            <li class="text-[11px] text-muted border border-cream-dark rounded-full px-2.5 py-1">{stage}</li>
          ))}
        </ul>
      )}
    </div>
  </article>
)}
