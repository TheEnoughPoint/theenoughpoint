---
// App promo block with store buttons
import ButtonApp from './ButtonApp.astro';
import { defaultFooterData, type FooterAppData } from '@src/data/footerData';

interface Props {
  app?: FooterAppData;
}

const { app = defaultFooterData.app } = Astro.props;
---

<div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8 items-start border-t border-slate-200 pt-10 pb-10">
  <div>
    <p class="font-display font-bold text-sm text-slate-900">{app.title}</p>
    <p class="text-slate-500 text-sm mt-2 leading-relaxed max-w-md">{app.description}</p>
  </div>
  <div class="flex items-center gap-3">
    {app.buttons.map((btn) => <ButtonApp {...btn} />)}
  </div>
</div>
