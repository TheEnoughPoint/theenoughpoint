---
import { url } from '@src/utils/path';

interface RelatedPost {
  slug:  string;
  title: string;
  cover: string;
  date:  string;
}

interface Props {
  posts: RelatedPost[];
  title?: string;
}

const { posts, title = 'Related Article' } = Astro.props;

if (!posts.length) return;

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', {
    day: '2-digit', month: 'short', year: 'numeric',
  });
}
---

<div class="py-6 md:py-8 border-b border-slate-200">
  <h3 class="text-xl font-medium mb-0">{title}</h3>
  <div class="pt-2 flex flex-col">
    {posts.map((post) => (
      <a
        href={url(`/${post.slug}`)}
        class="flex gap-3 py-3 border-b last:border-b-0 border-slate-200"
      >
        <img src={url(post.cover)} alt={post.title} class="size-16 object-cover shrink-0" />
        <div class="flex flex-col gap-1">
          <h4 class="capitalize hover:text-black line-clamp-2">{post.title}</h4>
          <span class="text-slate-500 text-sm">{formatDate(post.date)}</span>
        </div>
      </a>
    ))}
  </div>
</div>
