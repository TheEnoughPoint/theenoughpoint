---
import { Icon } from 'astro-icon/components';
import { url } from '@src/utils/path';
import type { AuthorData } from '@src/data/authorData';

interface Props {
  author: AuthorData;
}

const { author } = Astro.props;
---

<div class="flex flex-row items-center py-6 md:py-8 border-b border-slate-200">
  <!-- Avatar -->
  <div class="shrink-0 rounded-full overflow-hidden">
    <a href={url(author.href)}>
      <img src={url(author.avatar)} alt={author.fullName} class="size-20 rounded-full object-cover" />
    </a>
  </div>

  <!-- Info -->
  <div class="ms-6">
    <h4 class="text-xl">
      <a href={url(author.href)} class="hover:text-black">{author.fullName}</a>
    </h4>

    {author.website && (
      <p class="text-sm">
        <a
          href={author.website}
          target="_blank"
          rel="noopener"
          class="hover:text-black break-all"
        >
          {author.website}
        </a>
      </p>
    )}

    <p class="hidden sm:block text-sm text-slate-500 mt-1">{author.bio}</p>

    <!-- Social -->
    <div class="mt-6">
      <ul class="flex items-center gap-3">
        {author.socials.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              title={s.label}
              class="hover:text-slate-900 transition-opacity hover:opacity-70"
            >
              <Icon name={s.icon} class="size-5" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>
