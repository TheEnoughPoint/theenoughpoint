---
import { getCollection } from 'astro:content';
import { url } from '@src/utils/path';

interface Props {
  title?: string;
  limit?: number;
}

const { title = 'Category', limit = 8 } = Astro.props;

// Aggregate categories from all blog posts
const posts = await getCollection('blog');

const countMap = new Map<string, number>();
for (const post of posts) {
  const cat = post.data.category;
  countMap.set(cat, (countMap.get(cat) ?? 0) + 1);
}

// Sort by count desc, cap at limit
const categories = [...countMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, limit);

function categorySlug(cat: string) {
  return cat.toLowerCase().replace(/\s+/g, '-');
}
---

<div class="bg-slate-50 border border-slate-200 rounded-lg">
  <h3 class="w-full px-6 py-3 border-b border-slate-200">{title}</h3>
  <div class="py-3 px-6">
    <ul class="flex flex-col">
      {categories.map(([cat, count]) => (
        <li class="relative">
          <a
            href={url(`/${categorySlug(cat)}`)}
            class="flex items-center gap-3 justify-between py-1.5 hover:text-brand-600 transition-colors"
          >
            <span>{cat}</span>
            <span>({count})</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>
