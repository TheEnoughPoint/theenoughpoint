---
import { url } from '@src/utils/path';
import { defaultHeroData, type HeroGridItem } from '@src/data/heroData';

interface Props {
  grid?: HeroGridItem[];
}

const { grid = defaultHeroData.grid } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6">
  {grid.map((item) => (
    <div class="relative aspect-2/1 bg-slate-100 overflow-hidden flex justify-center items-center">
      <img src={url(item.image)} alt={item.imageAlt} class="absolute w-full inset-x-0 top-0" />
      <a href={url(item.href)} class="relative flex py-2 px-4 bg-white/80 hover:bg-white/95 transition-colors">
        {item.category}
      </a>
    </div>
  ))}
</div>
