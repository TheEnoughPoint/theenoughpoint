---
import { Icon } from 'astro-icon/components';
import { url } from '@src/utils/path';
import { pillars } from '@src/data/pillarsData';
---

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
  {pillars.map((p) => (
    <a
      href={url(`/${p.id}`)}
      class="group flex items-start gap-3 bg-white border border-cream-dark rounded-lg p-4 hover:border-brand-300 hover:shadow-sm transition-all"
    >
      <span class="shrink-0 flex items-center justify-center size-10 rounded-full bg-cream text-forest group-hover:bg-forest group-hover:text-white transition-colors">
        <Icon name={p.icon} class="size-4.5" />
      </span>
      <div>
        <p class="text-navy text-xs font-bold uppercase tracking-wide">{p.tileTitle}</p>
        <p class="text-muted text-xs mt-1 leading-snug">{p.description}</p>
      </div>
    </a>
  ))}
</div>
