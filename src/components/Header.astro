---
import { Icon } from 'astro-icon/components';
import { url } from '@src/utils/path';
import Logo from './Logo.astro';
import NavMenu from './NavMenu.astro';
import { defaultHeaderData, type HeaderData } from '@src/data/headerData';

interface Props {
  data?: Partial<HeaderData>;
}

const { data = {} } = Astro.props;

const merged: HeaderData = { ...defaultHeaderData, ...data };
---
<header class="sticky top-0 bg-white lg:border-y border-slate-200 z-70">
  <div class="container xl:max-w-7xl mx-auto px-4 flex items-center gap-3 justify-between">
    <!-- Hamburger -->
    <button @click="navtoggle = !navtoggle" class="size-10 text-2xl lg:hidden" aria-label="Toggle navigation">
      <Icon name="bi:x-lg" x-show="navtoggle" class="size-4" style="display:none" />
      <Icon name="bi:list" x-show="!navtoggle" class="size-5" />
    </button>

    <Logo src={merged.logo.src} alt={merged.logo.alt} width={merged.logo.width} />
    
    <div class="flex items-center gap-3">
      <!-- Navigation -->
      <NavMenu navMenu={merged.navMenu} copyright={merged.copyright} />
      <!-- Mobile search toggle -->
      <a href={url('/search')} class="flex items-center justify-center size-10 text-xl" aria-label="Open search">
        <Icon name="bi:search" class="size-4" />
      </a>
    </div>
  </div>
</header>