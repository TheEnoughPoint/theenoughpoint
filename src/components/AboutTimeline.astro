---
import type { AboutTimelineItem } from '@src/data/aboutData';

interface Props {
  timeline: AboutTimelineItem[];
  title?: string;
}

const { timeline, title = 'Our Milestones' } = Astro.props;
---

<div class="py-8 border-b border-cream-dark">
  <h2 class="text-xl font-heading font-bold text-navy mb-8">{title}</h2>

  <div class="relative flex flex-col gap-0">
    <!-- Vertical line -->
    <div class="absolute left-22 top-0 bottom-0 w-px border-l border-cream-dark hidden sm:block"></div>

    {timeline.map((item, i) => (
      <div class="flex gap-4 sm:gap-8 pb-8 last:pb-0 relative">
        <!-- Year badge -->
        <div class="shrink-0 w-20 text-right">
          <span class="text-sm font-medium text-muted leading-6">{item.year}</span>
        </div>

        <!-- Dot -->
        <div class="hidden sm:flex shrink-0 items-start justify-center w-4 pt-1 -mx-2 relative z-10">
          <div class:list={[
            'size-3 rounded-full border-2 border-gold',
            i === timeline.length - 1 ? 'bg-gold' : 'bg-white',
          ]}></div>
        </div>

        <!-- Content -->
        <div class="flex flex-col gap-1 pb-2">
          <h3 class="font-semibold text-base text-navy">{item.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>
