---
// Single store button (App Store / Google Play)
import { Icon } from 'astro-icon/components';
import { url } from '@src/utils/path';
import type { FooterAppButton } from '@src/data/footerData';

interface Props extends FooterAppButton {}

const { icon, caption, label, href } = Astro.props;
---

<a href={url(href)} class="flex items-center gap-2 bg-slate-900 text-white px-4 py-2.5 rounded-md hover:bg-slate-800 transition-colors">
  <Icon name={icon} class="text-xl" />
  <span class="text-left leading-tight">
    <span class="block text-[10px] text-slate-300">{caption}</span>
    <span class="block text-sm font-semibold">{label}</span>
  </span>
</a>
