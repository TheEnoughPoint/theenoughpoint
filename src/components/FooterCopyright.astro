---
// Bottom copyright bar with legal links
import { url } from '@src/utils/path';
import { defaultFooterData, type FooterCopyrightData } from '@src/data/footerData';

interface Props {
  copyright?: FooterCopyrightData;
}

const { copyright = defaultFooterData.copyright } = Astro.props;
---

<div class="flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-cream-dark pt-6">
  <p class="text-muted text-sm">{copyright.text}</p>
  <div class="flex items-center gap-6">
    {copyright.links.map((link) => (
      <a href={url(link.href)} class="text-muted text-sm hover:text-brand-600 transition-colors">{link.label}</a>
    ))}
  </div>
</div>
