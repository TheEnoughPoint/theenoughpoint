---
import { Icon } from 'astro-icon/components';
---
 
<button
  x-data="{ visible: false }"
  x-init="window.addEventListener('scroll', () => { visible = window.scrollY > 300 })"
  x-show="visible"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0 translate-y-4"
  x-transition:enter-end="opacity-100 translate-y-0"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100 translate-y-0"
  x-transition:leave-end="opacity-0 translate-y-4"
  @click="window.scrollTo({ top: 0, behavior: 'smooth' })"
  class="fixed py-2 px-3 rounded-lg bg-slate-50 border border-slate-200 text-slate-500 inset-e-4 bottom-4 cursor-pointer hover:bg-slate-100 hover:text-slate-700 transition-colors z-50"
  aria-label="Scroll To Top"
  x-cloak
>
  <Icon name="bi:arrow-up" class="size-4" />
</button>